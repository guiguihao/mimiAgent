{
  "mcpServers": {
    "ureal-mcp": {
      "enabled": true,
      "command": "python3",
      "args": [
        "../mcp/ureal-mcp/server.py"
      ]
    },
    "miot-mcp": {
      "enabled": false,
      "command": "python3",
      "args": [
        "../mcp/miot-mcp/mcp_server/mcp_server.py"
      ],
      "env": {
        "MIJIA_LOG_LEVEL": "INFO"
      }
    },
    "xiaodu-mcp": {
      "enabled": false,
      "url": "https://xiaodu.baidu.com/dueros_mcp_server/mcp/",
      "headers": {
        "ACCESS_TOKEN": "${XIAODU_ACCESS_TOKEN}"
      }
    }
  }
}